{
  "name": "shelbz-citrine-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "packages": [
      "frontend",
      "backend",
      "backend/src/plugins/wysiwyg-editor",
      "backend/src/plugins/color-picker",
      "backend/src/plugins/form-layout-editor"
    ],
    "nohoist": [
      "**/sharp",
      "**/@img/**",
      "**/sharp-libvips-*"
    ]
  },
  "scripts": {
    "frontend": "yarn workspace shelbz-citrine-frontend dev",
    "backend": "yarn workspace shelbz-citrine-backend develop",
    "build:backend": "yarn install && yarn workspace shelbz-citrine-backend build",
    "build:frontend": "yarn install && yarn workspace shelbz-citrine-frontend build",
    "dev": "concurrently \"yarn frontend\" \"yarn backend\"",
    "images:publish": "yarn workspace shelbz-citrine-backend images:publish",
    "icloud:save": "yarn workspace shelbz-citrine-backend icloud:save",
    "icloud:restore": "yarn workspace shelbz-citrine-backend icloud:restore",
    "icloud:status": "yarn workspace shelbz-citrine-backend icloud:status",
    "generate:strapi-client-types": "node scripts/generate-strapi-client-types.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "babel-jest": "^30.3.0",
    "concurrently": "^9.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  },
  "resolutions": {
    "@radix-ui/react-slot": "^1.2.3"
  }
}
