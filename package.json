{
  "name": "shelbz-citrine-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "packages": [
      "frontend",
      "backend"
    ],
    "nohoist": [
      "**/sharp",
      "**/@img/**",
      "**/sharp-libvips-*"
    ]
  },
  "scripts": {
    "frontend": "yarn workspace dark-lux-storefront dev",
    "backend": "yarn workspace shelbz-citrine-backend develop",
    "dev": "concurrently \"yarn frontend\" \"yarn backend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "resolutions": {
    "@radix-ui/react-slot": "^1.2.3"
  }
}
