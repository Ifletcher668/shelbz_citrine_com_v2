{
  "collectionName": "components_sections_rows",
  "info": {
    "displayName": "Row",
    "icon": "grid",
    "description": "A row containing up to six WYSIWYG columns. Column order determines layout position."
  },
  "options": {},
  "attributes": {
    "row_name": {
      "type": "string",
      "private": true
    },
    "section_id": {
      "type": "string",
      "unique": true,
      "regex": "^[a-z]+(-[a-z]+)*$"
    },
    "columns": {
      "type": "component",
      "component": "column.column",
      "repeatable": true,
      "min": 1,
      "max": 6
    }
  }
}
