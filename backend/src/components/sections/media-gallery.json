{
  "collectionName": "components_sections_media_galleries",
  "info": {
    "displayName": "Media Gallery",
    "icon": "landscape",
    "description": "A paginated or filterable image gallery, sourced from the Strapi Media Library"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "Images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "use_pagination": {
      "type": "boolean"
    },
    "pagination_filter": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "use_pagination"
            },
            true
          ]
        }
      },
      "enum": [
        "year",
        "number"
      ]
    },
    "pagination_count": {
      "type": "integer",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "pagination_filter"
            },
            "number"
          ]
        }
      },
      "min": 1
    }
  }
}
