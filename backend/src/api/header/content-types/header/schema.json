{
  "kind": "singleType",
  "collectionName": "headers",
  "info": {
    "singularName": "header",
    "pluralName": "headers",
    "displayName": "Header"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "primary": {
      "type": "dynamiczone",
      "components": [
        "navigation.logo-image",
        "navigation.logo-text"
      ],
      "max": 1
    },
    "navigation": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::navigation.navigation"
    },
    "title": {
      "type": "string",
      "private": true,
      "default": "Header",
      "required": true,
      "unique": true
    },
    "header_cta": {
      "type": "component",
      "component": "ui.button-link",
      "repeatable": false
    }
  }
}
