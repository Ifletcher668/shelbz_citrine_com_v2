{
  "kind": "collectionType",
  "collectionName": "buttons",
  "info": {
    "singularName": "button",
    "pluralName": "buttons",
    "displayName": "Button",
    "description": "A reusable button embeddable in WYSIWYG content via [ref:button:id]. Either action or link should be set, not both."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "private": true
    },
    "text": {
      "type": "string",
      "required": true
    },
    "variant": {
      "type": "enumeration",
      "enum": ["primary", "secondary", "tertiary"],
      "default": "primary",
      "required": true
    },
    "action": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::action.action"
    },
    "link": {
      "type": "component",
      "component": "ui.button-link",
      "repeatable": false
    }
  }
}
