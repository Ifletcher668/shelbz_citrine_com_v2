{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "CMS-driven pages with composable section layouts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "seo_description": {
      "type": "text",
      "maxLength": 320
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.row",
        "sections.media-gallery"
      ]
    },
    "parent_page": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::page.page",
      "inversedBy": "sub_pages"
    },
    "sub_pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "parent_page"
    },
    "page_template": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::page-template.page-template",
      "inversedBy": "pages"
    },
    "custom_css": {
      "type": "customField",
      "customField": "plugin::css-editor.css-editor"
    }
  }
}
