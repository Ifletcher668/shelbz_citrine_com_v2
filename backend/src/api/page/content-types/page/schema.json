{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "CMS-driven pages with composable section layouts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "seo_description": {
      "type": "text",
      "maxLength": 320
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.row",
        "sections.media-gallery"
      ]
    },
    "theme_overrides": {
      "type": "json"
    },
    "sub_page": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::page.page",
      "inversedBy": "parent_pages"
    },
    "parent_pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "sub_page"
    }
  }
}
