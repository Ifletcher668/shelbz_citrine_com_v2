{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "CMS-driven pages with composable section layouts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "seo_description": {
      "type": "text",
      "maxLength": 320
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.column-group",
        "sections.step-group",
        "sections.gallery",
        "sections.faq",
        "sections.image",
        "sections.button"
      ]
    }
  }
}
