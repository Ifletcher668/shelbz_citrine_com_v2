HOST=0.0.0.0
PORT=1337
APP_KEYS=your,generated,keys,here
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
# For PostgreSQL (production):
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
CORS_ORIGINS=http://localhost:3000,http://localhost:1337

# Cloudinary (media upload provider)
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# Preview (Strapi admin preview button → Netlify Preview Servers)
FRONTEND_URL=https://your-site.netlify.app
PREVIEW_SECRET=your-preview-secret
NETLIFY_PREVIEW_SERVER_HOOK=https://api.netlify.com/preview_server_hooks/your-hook-id
