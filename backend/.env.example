HOST=0.0.0.0
PORT=1337
APP_KEYS=your,generated,keys,here
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# CORS origins allowed to call this Strapi instance (comma-separated)
# Development default: http://localhost:3000,http://localhost:1337
# Production: set to your deployed frontend URL (e.g. https://shelbzcitrine.com)
CORS_ORIGINS=http://localhost:3000,http://localhost:1337
