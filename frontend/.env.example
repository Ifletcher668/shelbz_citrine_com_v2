# Strapi backend URL
# Development: http://localhost:1337 (default, no need to set)
# Netlify build: set this to a tunnel URL or leave unset to skip CMS pages
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API token (read-only)
# Generate in Strapi admin: Settings > API Tokens > Create new token (type: Read-only)
# DO NOT use NEXT_PUBLIC_ prefix — this must stay server-side only
STRAPI_API_TOKEN=your-read-only-api-token
