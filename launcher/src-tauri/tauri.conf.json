{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shelbz Web Manager",
  "version": "0.1.0",
  "identifier": "com.shelbzcitrine.launcher",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ui",
    "beforeBuildCommand": "npm run build --prefix ui",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Shelbz Web Manager",
        "width": 400,
        "height": 680,
        "resizable": true,
        "visible": true,
        "maximized": true,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
